/* ===== СОВРЕМЕННЫЙ СТИЛЬ С ЭФФЕКТОМ СТЕКЛА (GLASSMORPHISM) ===== */

/* Импорт современных шрифтов */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&display=swap');

/* CSS-переменные для цветовой схемы */
:root {
    --bg-dark: #0a0c0f;
    --bg-card: rgba(20, 25, 30, 0.7);
    --text-primary: #ffffff;
    --text-secondary: #b0b8c0;
    --accent-blue: #2b7fff;
    --accent-green: #00c48c;
    --accent-red: #ff5c5c;
    --border-light: rgba(255, 255, 255, 0.1);
    --border-accent: rgba(43, 127, 255, 0.4);
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

body {
    background: var(--bg-dark);
    background-image: 
        radial-gradient(circle at 20% 30%, rgba(43, 127, 255, 0.1) 0%, transparent 40%),
        radial-gradient(circle at 80% 70%, rgba(0, 196, 140, 0.1) 0%, transparent 40%);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    margin: 0;
    padding: 20px;
    min-height: 100vh;
    color: var(--text-primary);
    font-size: 16px;
    line-height: 1.6;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

/* Основной контейнер (эффект стекла) */
.trip-card {
    max-width: 1000px;
    margin: 0 auto;
    background: var(--bg-card);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid var(--border-light);
    border-radius: 24px;
    padding: 35px;
    box-shadow: var(--shadow);
}

/* Навигационное меню */
.nav-menu {
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border-light);
    border-radius: 60px;
    padding: 12px 20px;
    margin-bottom: 30px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
}

.nav-menu a {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    padding: 6px 15px;
    border-radius: 40px;
    transition: all 0.2s ease;
    border: 1px solid transparent;
}

.nav-menu a:hover {
    color: white;
    background: var(--accent-blue);
    border-color: var(--accent-blue);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(43, 127, 255, 0.3);
}

.nav-menu a.active {
    background: var(--accent-blue);
    color: white;
    border-color: var(--accent-blue);
}

/* Заголовки с градиентом */
h1 {
    color: var(--text-primary);
    text-align: center;
    font-size: 2.8rem;
    font-weight: 600;
    letter-spacing: -0.5px;
    margin: 0 0 20px;
    background: linear-gradient(135deg, #fff 0%, #a0b0c0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

h2 {
    color: var(--text-primary);
    font-size: 2rem;
    font-weight: 500;
    margin: 40px 0 20px;
    border-left: 4px solid var(--accent-blue);
    padding-left: 20px;
    text-shadow: 0 2px 5px rgba(0,0,0,0.3);
}

h3 {
    color: var(--text-primary);
    font-size: 1.4rem;
    font-weight: 500;
    margin: 20px 0 10px;
}

/* Карточки (общий стиль) */
.place-card, .attraction-card, .day-highlight, .flight-card, .hotel-card, .route-card {
    background: rgba(15, 20, 25, 0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border-light);
    border-radius: 20px;
    padding: 25px;
    margin: 20px 0;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}

.place-card:hover, .attraction-card:hover, .day-highlight:hover {
    border-color: var(--border-accent);
    box-shadow: 0 8px 30px rgba(43, 127, 255, 0.2);
    transform: translateY(-2px);
}

.place-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 15px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 10px;
}

.place-name {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-primary);
}

.place-header span:last-child {
    background: rgba(255,255,255,0.1);
    padding: 4px 12px;
    border-radius: 40px;
    font-size: 0.9rem;
    color: var(--text-secondary);
    border: 1px solid rgba(255,255,255,0.1);
}

/* Цены и информация */
.price-info, .price-summary {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 15px 20px;
    margin: 15px 0;
}

.price-item {
    display: flex;
    justify-content: space-between;
    margin: 8px 0;
    border-bottom: 1px dashed rgba(255,255,255,0.1);
    padding-bottom: 6px;
}

.price-label {
    font-weight: 500;
    color: var(--text-secondary);
}

.price-value {
    color: var(--accent-green);
    font-weight: 600;
    font-family: 'Inter', monospace;
}

/* Кнопки */
.map-button, .nav-button {
    display: inline-block;
    background: transparent;
    color: var(--text-primary);
    padding: 10px 24px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    border: 1px solid var(--border-light);
    transition: all 0.2s ease;
    margin: 5px 5px 5px 0;
    cursor: pointer;
}

.map-button:hover, .nav-button:hover {
    background: var(--accent-blue);
    border-color: var(--accent-blue);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(43, 127, 255, 0.3);
}

.nav-button.active {
    background: var(--accent-blue);
    border-color: var(--accent-blue);
    color: white;
}

/* Блок советов и заметок */
.tip, .weather-note, .evening-plan, .morning-plan {
    background: rgba(20, 30, 40, 0.5);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 20px 25px;
    margin: 30px 0;
    border-left: 4px solid var(--accent-green);
}

.tip strong {
    color: var(--accent-green);
}

/* Таблицы */
table {
    width: 100%;
    border-collapse: collapse;
    margin: 30px 0;
    background: rgba(0,0,0,0.2);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
}

th {
    background: rgba(43, 127, 255, 0.2);
    color: var(--text-primary);
    font-weight: 600;
    padding: 12px 15px;
    text-align: left;
    border-bottom: 1px solid rgba(255,255,255,0.1);
}

td {
    padding: 12px 15px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    color: var(--text-secondary);
}

tr:last-child td {
    border-bottom: none;
}

tr:hover td {
    background: rgba(255,255,255,0.05);
}

/* Код бронирования */
.booking-ref {
    background: rgba(43, 127, 255, 0.2);
    border: 1px solid rgba(43, 127, 255, 0.3);
    color: var(--accent-blue);
    padding: 4px 10px;
    border-radius: 20px;
    font-family: 'Inter', monospace;
    font-size: 0.9rem;
    font-weight: 600;
}

/* Подвал */
.footer {
    text-align: center;
    margin-top: 50px;
    padding-top: 25px;
    border-top: 1px solid rgba(255,255,255,0.1);
    color: var(--text-secondary);
    font-size: 0.95rem;
}

/* Японский акцент */
.japanese-accent {
    color: var(--accent-red);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
}

/* Специфические классы для страниц */
.city-badge {
    display: inline-block;
    background: rgba(43, 127, 255, 0.15);
    border: 1px solid rgba(43, 127, 255, 0.3);
    color: var(--accent-blue);
    padding: 5px 15px;
    border-radius: 40px;
    font-size: 0.9rem;
    font-weight: 500;
    margin-right: 8px;
    margin-bottom: 8px;
}

.currency-note {
    background: rgba(255, 200, 0, 0.1);
    border-left: 4px solid #f0b400;
    padding: 10px 15px;
    border-radius: 12px;
    margin: 20px 0;
    font-size: 0.95rem;
    color: var(--text-secondary);
}

/* Адаптация для мобильных устройств (сохраняем плотность) */
@media (max-width: 768px) {
    body {
        padding: 10px;
    }
    
    .trip-card {
        padding: 15px;
    }
    
    h1 {
        font-size: 2.2rem;
    }
    
    h2 {
        font-size: 1.6rem;
    }
    
    .nav-menu {
        padding: 8px 12px;
    }
    
    .nav-menu a {
        font-size: 0.8rem;
        padding: 4px 10px;
    }
    
    /* Сетка городов на главной – в две колонки */
    .city-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
    }
    
    .city-card {
        padding: 10px 6px;
        background: rgba(15, 20, 25, 0.7);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        text-align: center;
    }
    
    .city-icon {
        font-size: 2.2rem;
        margin-bottom: 3px;
    }
    
    .city-name {
        font-size: 1rem;
    }
    
    .city-dates, .city-tagline {
        font-size: 0.7rem;
    }
    
    .city-address {
        font-size: 0.65rem;
        padding-top: 3px;
    }
    
    /* Таблица перелётов */
    .flight-badge {
        padding: 8px;
    }
    
    .flight-row {
        font-size: 0.75rem;
        padding: 3px 0;
        flex-wrap: wrap;
    }
    
    /* Карточки отелей и дней */
    .hotel-card, .day-highlight, .attraction-card {
        padding: 12px;
    }
    
    .timeline-item {
        margin: 4px 0;
    }
    
    .timeline-time {
        min-width: 60px;
        font-size: 0.75rem;
    }
    
    .timeline-desc {
        font-size: 0.75rem;
    }
    
    /* Таблицы расходов */
    table {
        font-size: 0.7rem;
    }
    
    th, td {
        padding: 4px 6px;
    }
    
    /* Кнопки */
    .map-button, .nav-button {
        padding: 6px 12px;
        font-size: 0.8rem;
    }
    
    /* Блок цен */
    .price-info {
        padding: 8px 10px;
        font-size: 0.8rem;
    }
    
    /* Карта */
    .map-container iframe {
        height: 300px;
    }
}
